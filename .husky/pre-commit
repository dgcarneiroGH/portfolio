#!/bin/sh
. "$(dirname "$0")/_/husky.sh"

# Get current branch name
branch=$(git rev-parse --abbrev-ref HEAD)

# Only run checks on main branch
if [ "$branch" = "main" ]; then
  echo "🔍 Pre-commit checks running on main branch..."
  
  # Run tests first
  echo "🧪 Running tests..."
  npm run test:ci
  test_exit_code=$?
  
  if [ $test_exit_code -ne 0 ]; then
    echo "❌ Tests failed! Commit aborted."
    exit 1
  fi
  
  echo "✅ All tests passed!"
  
  # Run ESLint
  echo "🔧 Running ESLint..."
  ng lint
  lint_exit_code=$?
  
  if [ $lint_exit_code -ne 0 ]; then
    echo "❌ ESLint found errors! Commit aborted."
    echo "💡 Warnings are allowed, but errors must be fixed."
    echo "💡 Run 'ng lint' to see detailed errors."
    exit 1
  fi
  
  echo "✅ ESLint check passed!"
  echo "🎉 All pre-commit checks passed. Proceeding with commit..."
  
else
  echo "ℹ️  Pre-commit checks skipped (not on main branch)"
fi
