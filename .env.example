# ===========================================
# Portfolio - Environment Variables Setup
# ===========================================
# Para usar este proyecto en un nuevo ordenador:
# 1. Copia este archivo como .env en la raíz del proyecto
# 2. Completa las variables con los valores reales
# 3. Los valores están en tu gestor de contraseñas/documentación privada

# Token de seguridad para el webhook de N8N
PORTFOLIO_TOKEN=your-actual-token-here

# URL del webhook de N8N (development/production)
N8N_WEBHOOK_URL=https://n8n.nomacoda.com/webhook/portfolio-contact-form

# ===========================================
# INSTRUCCIONES DE CONFIGURACIÓN:
# ===========================================
# Para desarrollo local:
#   1. npm install
#   2. cp .env.example .env
#   3. Completa las variables arriba con valores reales
#   4. npm run dev (con Netlify Functions)
#   OR
#   4. npm start (solo Angular)
#
# Para producción:
#   - Variables configuradas en Netlify Dashboard:
#     Site Settings → Environment Variables
# ===========================================