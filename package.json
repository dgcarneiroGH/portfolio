{
  "name": "portfolio",
  "homepage": "",
  "version": "1.0.0",
  "scripts": {
    "start": "ng serve",
    "build": "ng build --base-href",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d dist/portfolio",
    "format": "prettier \"src/**/*.html\" --write",
    "format:check": "prettier \"src/**/*.html\" --check",
    "compodoc": "npx compodoc -p tsconfig.doc.json -w -s --hideGenerator",
    "watch": "ng build --watch --configuration development",
    "test": "ng test"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^20.3.17",
    "@angular/common": "^20.3.17",
    "@angular/compiler": "^20.3.17",
    "@angular/core": "^20.3.17",
    "@angular/forms": "^20.3.17",
    "@angular/platform-browser": "^20.3.17",
    "@angular/platform-browser-dynamic": "^20.3.17",
    "@angular/router": "^20.3.17",
    "@ngx-translate/core": "^16.0.4",
    "@ngx-translate/http-loader": "^16.0.1",
    "@portabletext/to-html": "^3.0.0",
    "@sanity/client": "^7.12.1",
    "@sanity/image-url": "^1.2.0",
    "blast-vanilla": "^2.1.6",
    "colorthief": "^3.3.1",
    "flag-icons": "^7.5.0",
    "gh-pages": "^6.2.0",
    "ng-tagcanvas": "^1.0.2",
    "rxjs": "~7.8.1",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@angular/build": "^20.3.18",
    "@angular/cli": "^20.3.18",
    "@angular/compiler-cli": "^20.3.17",
    "@compodoc/compodoc": "^1.1.26",
    "@eslint/js": "^9.30.1",
    "@types/jasmine": "~5.1.5",
    "baseline-browser-mapping": "^2.9.14",
    "eslint": "^9.30.1",
    "globals": "^16.3.0",
    "jasmine-core": "~5.5.0",
    "karma": "~6.4.4",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.1",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "prettier": "^3.6.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.36.0"
